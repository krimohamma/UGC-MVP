# Supabase project settings (Project Settings > API in the Supabase dashboard).
# Safe to expose to the browser: prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret key (replaces the legacy service_role key). NEVER prefix with
# NEXT_PUBLIC_ — this bypasses Row Level Security and must only ever be read
# from server-only code (lib/supabase/admin.ts).
SUPABASE_SECRET_KEY=your-secret-key

# JWKS endpoint for locally verifying Supabase Auth JWTs (asymmetric signing
# keys). Not read by any code in this repo yet — kept here so it's not lost,
# wire it up if/when local JWT verification is added.
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Direct Postgres connection string, used only for `supabase gen types --db-url`
# and other CLI/migration tasks — not read by the app itself.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
